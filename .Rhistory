import zipfile
import os
import numpy as np
from PIL import Image
import pandas as pd

# Path to your dataset ZIP
zip_path = r"C:\Users\damer\Downloads\Driver Drowsiness Dataset (DDD).zip"

# Extract zip file to a folder
extract_path = r"C:\Users\damer\Downloads\DDD_Extracted"
with zipfile.ZipFile(zip_path, 'r') as zip_ref:
    zip_ref.extractall(extract_path)

print("Dataset extracted to:", extract_path)

# Prepare lists for data and labels
data = []
labels = []

# Loop through all folders and images
for root, dirs, files in os.walk(extract_path):
    for file in files:
        if file.lower().endswith((".jpg", ".jpeg", ".png")):
            img_path = os.path.join(root, file)

            # Open image and convert to grayscale
            img = Image.open(img_path).convert("L")

            # Resize to smaller size (e.g., 28x28 for Excel usability)
            img = img.resize((28, 28))

            # Convert image to numpy array and flatten
            arr = np.array(img).flatten()

            # Append image data
            data.append(arr)

            # Label = parent folder name (adjust if needed)
            label = os.path.basename(root)
            labels.append(label)

# Convert to DataFrame
df = pd.DataFrame(data)
df.insert(0, "label", labels)

# Save to Excel
output_path = r"C:\Users\damer\Downloads\driver_drowsiness.xlsx"
df.to_excel(output_path, index=False)

print("Excel file created at:", output_path)
